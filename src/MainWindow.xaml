<Window x:Class="TextBouncer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hx="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
        Title="3D Text Bouncer" Height="720" Width="1280"
        Background="#1e1e1e"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Side panel (WPF controls) -->
        <Border DockPanel.Dock="Left" Width="420" Background="#282828" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Text Input -->
                    <TextBox x:Name="TextInputBox"
                             Text="Hello"
                             FontSize="14"
                             Padding="5"
                             Margin="0,5,0,10"
                             Width="380"/>

                    <!-- Color picker -->
                    <Button x:Name="ColorButton"
                            Content="Choose Color"
                            Height="28"
                            Margin="0,0,0,5"/>
                    <Label x:Name="ColorLabel"
                           Content="Color: White"
                           Foreground="White"
                           Margin="0,0,0,15"/>

                    <!-- Particle count slider -->
                    <Label x:Name="ParticleCountLabel"
                           Content="Particles: 10,000"
                           Foreground="White"/>
                    <Slider x:Name="ParticleCountSlider"
                            Minimum="1000" Maximum="100000"
                            Value="10000"
                            TickFrequency="10000"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,15"/>

                    <!-- Box opacity slider -->
                    <Label x:Name="BoxOpacityLabel"
                           Content="Box Face Opacity: 40%"
                           Foreground="White"/>
                    <Slider x:Name="BoxOpacitySlider"
                            Minimum="0" Maximum="100"
                            Value="40"
                            TickFrequency="10"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,5"/>

                    <!-- Box transparency mode -->
                    <GroupBox Header="Box Transparency Mode" Foreground="White" Margin="0,0,0,10">
                        <StackPanel>
                            <RadioButton x:Name="WireframeOnlyRadio"
                                        Content="Wireframe Only"
                                        Foreground="White"
                                        Checked="OnTransparencyModeChanged"
                                        Margin="0,5,0,0"/>
                            <RadioButton x:Name="FaceTransparencyRadio"
                                        Content="Face Only"
                                        Foreground="White"
                                        Checked="OnTransparencyModeChanged"
                                        Margin="0,5,0,0"/>
                            <RadioButton x:Name="WholeTransparencyRadio"
                                        Content="Whole Polyhedron"
                                        Foreground="White"
                                        IsChecked="True"
                                        Checked="OnTransparencyModeChanged"
                                        Margin="0,5,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Fill rule mode -->
                    <GroupBox Header="Fill Rule" Foreground="White" Margin="0,0,0,10">
                        <StackPanel>
                            <ComboBox x:Name="FillRuleCombo"
                                      Height="24"
                                      Margin="0,5,0,5"
                                      SelectionChanged="OnFillRuleChanged"
                                      HorizontalContentAlignment="Left">
                                <ComboBoxItem Content="Fan from Centroid" IsSelected="True"/>
                                <ComboBoxItem Content="Ear Clipping (Even-Odd)"/>
                                <ComboBoxItem Content="Convex Hull (Non-Zero)"/>
                                <ComboBoxItem Content="Fan from Vertex 0"/>
                                <ComboBoxItem Content="Strip Partition"/>
                                <ComboBoxItem Content="Neighbor Fan"/>
                                <ComboBoxItem Content="Kirkpatrick Fan"/>
                                <ComboBoxItem Content="Monotone Partition"/>
                                <ComboBoxItem Content="Minimum Diagonal"/>
                                <ComboBoxItem Content="Alternating Fan"/>
                                <ComboBoxItem Content="Dial (Min Angle)"/>
                                <ComboBoxItem Content="Star Bipartition"/>
                            </ComboBox>
                            <TextBlock x:Name="FillRuleDesc"
                                       Text="Simple fan from centroid - fast but only correct for convex faces"
                                       Foreground="LightGray"
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Rule resets when switching polyhedron"
                                       Foreground="Gray"
                                       FontSize="9"
                                       Margin="0,0,0,5"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Polyhedron selector slider -->
                    <Label x:Name="PolyhedronLabel"
                           Content="Polyhedron: Cube"
                           Foreground="White"/>
                    <Slider x:Name="PolyhedronSlider"
                            Minimum="0" Maximum="47"
                            Value="1"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,5"/>

                    <!-- Control target toggle -->
                    <GroupBox Header="Control Target" Foreground="White" Margin="0,0,0,10">
                        <StackPanel>
                            <RadioButton x:Name="CameraControlRadio"
                                        Content="Camera"
                                        Foreground="White"
                                        IsChecked="True"
                                        Checked="OnControlTargetChanged"
                                        Margin="0,5,0,0"/>
                            <RadioButton x:Name="TextControlRadio"
                                         Content="Scene"
                                         Foreground="White"
                                         Checked="OnControlTargetChanged"
                                         Margin="0,5,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Camera controls -->
                    <StackPanel x:Name="CameraControlsPanel">
                        <Label Content="Camera Position" Foreground="White" FontWeight="Bold"/>
                        <Label x:Name="PosXLabel" Content="Cam Pos X: 0.00" Foreground="White"/>
                        <Slider x:Name="PosXSlider"
                                Minimum="-500" Maximum="500"
                                Value="0"
                                TickFrequency="100"
                                Margin="0,0,0,5"/>

                        <Label x:Name="PosYLabel" Content="Cam Pos Y: 0.00" Foreground="White"/>
                        <Slider x:Name="PosYSlider"
                                Minimum="-500" Maximum="500"
                                Value="0"
                                TickFrequency="100"
                                Margin="0,0,0,5"/>

                        <Label x:Name="PosZLabel" Content="Cam Pos Z: 0.00" Foreground="White"/>
                        <Slider x:Name="PosZSlider"
                                Minimum="-1000" Maximum="1000"
                                Value="0"
                                TickFrequency="200"
                                Margin="0,0,0,5"/>

                        <Label Content="Camera Rotation" Foreground="White" FontWeight="Bold" Margin="0,10,0,0"/>
                        <Label x:Name="PitchLabel" Content="Cam Pitch: 0°" Foreground="White"/>
                        <Slider x:Name="PitchSlider"
                                Minimum="-180" Maximum="180"
                                Value="0"
                                TickFrequency="45"
                                Margin="0,0,0,5"/>

                        <Label x:Name="RollLabel" Content="Cam Roll: 0°" Foreground="White"/>
                        <Slider x:Name="RollSlider"
                                Minimum="-180" Maximum="180"
                                Value="0"
                                TickFrequency="45"
                                Margin="0,0,0,5"/>

                        <Label x:Name="YawLabel" Content="Cam Yaw: 0°" Foreground="White"/>
                        <Slider x:Name="YawSlider"
                                Minimum="-180" Maximum="180"
                                Value="0"
                                TickFrequency="45"
                                Margin="0,0,0,5"/>
                    </StackPanel>

                    <!-- Scene controls -->
                    <StackPanel x:Name="TextControlsPanel" Visibility="Collapsed">
                        <Label Content="Box Position" Foreground="White" FontWeight="Bold"/>
                        <Label x:Name="TextPosXLabel" Content="Box Pos X: 0.00" Foreground="White"/>
                        <Slider x:Name="TextPosXSlider"
                                Minimum="-100" Maximum="100"
                                Value="0"
                                TickFrequency="10"
                                Margin="0,0,0,5"/>

                        <Label x:Name="TextPosYLabel" Content="Box Pos Y: 0.00" Foreground="White"/>
                        <Slider x:Name="TextPosYSlider"
                                Minimum="-100" Maximum="100"
                                Value="0"
                                TickFrequency="10"
                                Margin="0,0,0,5"/>

                        <Label x:Name="TextPosZLabel" Content="Box Pos Z: 0.00" Foreground="White"/>
                        <Slider x:Name="TextPosZSlider"
                                Minimum="-100" Maximum="100"
                                Value="0"
                                TickFrequency="10"
                                Margin="0,0,0,5"/>

                        <Label Content="Box Rotation" Foreground="White" FontWeight="Bold" Margin="0,10,0,0"/>
                        <Label x:Name="TextPitchLabel" Content="Box Pitch: 0°" Foreground="White"/>
                        <Slider x:Name="TextPitchSlider"
                                Minimum="-180" Maximum="180"
                                Value="0"
                                TickFrequency="45"
                                Margin="0,0,0,5"/>

                        <Label x:Name="TextRollLabel" Content="Box Roll: 0°" Foreground="White"/>
                        <Slider x:Name="TextRollSlider"
                                Minimum="-180" Maximum="180"
                                Value="0"
                                TickFrequency="45"
                                Margin="0,0,0,5"/>

                        <Label x:Name="TextYawLabel" Content="Box Yaw: 0°" Foreground="White"/>
                        <Slider x:Name="TextYawSlider"
                                Minimum="-180" Maximum="180"
                                Value="0"
                                TickFrequency="45"
                                Margin="0,0,0,5"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Helix 3D viewport (fills remaining space) -->
        <hx:HelixViewport3D x:Name="Viewport"
                           Background="#6378c8"
                           ShowCoordinateSystem="True"
                           ZoomExtentsWhenLoaded="True">
            <hx:DefaultLights/>

            <!-- Box: 6 faces as separate visuals -->
            <hx:LinesVisual3D x:Name="BoxWireframe"
                              Color="White"
                              Thickness="1"/>
        </hx:HelixViewport3D>
    </DockPanel>
</Window>
